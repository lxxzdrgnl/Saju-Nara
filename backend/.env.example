# LLM Provider ("gemini" | "openai" | "claude", 기본: gemini)
LLM_PROVIDER=gemini

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embedding (RAG용)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001

# ChromaDB — backend/chroma_db 에 재인덱싱 후 ./chroma_db 로 변경
CHROMA_PATH=../mcp-servers/saju-rag/chroma_db

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sajunara

PORT=8000
